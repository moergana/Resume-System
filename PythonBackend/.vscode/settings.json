{
    "basedpyright.analysis.typeCheckingMode": "basic",      // 设置basedpyright的类型检查模式，控制严格程度
    "basedpyright.analysis.diagnosticMode": "openFilesOnly",  // 设置basedpyright的诊断模式，控制诊断范围
    "basedpyright.analysis.useLibraryCodeForTypes": true,  // 设置basedpyright的类型推断模式，控制类型推断
    "basedpyright.analysis.autoSearchPaths": true,  // 设置basedpyright的自动搜索路径模式，控制搜索路径

    "python.testing.autoTestDiscoverOnSaveEnabled": false,  // 禁用保存时自动测试发现
    "python.testing.unittestArgs": [
        "-v",   // -v 参数设置测试的详细输出模式
        "-s",   // -s 参数设置搜索测试文件的目录，应该指定为单元测试文件所在目录
        "${workspaceFolder}/ResumeAnalyse/UnitTest",
        "-p",   // -p 参数设置测试文件的名称模式
        "*test*.py",
        "-t",   // -t 参数设置测试的根目录，这与import本地模块时的路径有关，推荐设置为工作目录
        "${workspaceFolder}"
    ]
}